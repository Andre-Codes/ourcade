# Anthropic API key for build-time content generation (scripts/generate-content.js).
# This is ONLY used by the generator/CI — it is never imported by the app and
# never ships to the browser.
#
# Local:  copy this file to .env and paste your key, then `npm run generate`.
# CI:     set it as the ANTHROPIC_API_KEY repository secret (used by
#         .github/workflows/generate-content.yml).
ANTHROPIC_API_KEY=
